# =============================================================================
# .gitignore — MFMA Course
# =============================================================================

# Binärer / Binaries
hello_hip
wavefront_basics
lds_memory
mfma_intro
mfma_gemm
*_debug

# Kompilatorns mellanfiler / Compiler intermediates
*.o
*.ll
*.bc
*.hipi
*.hipfb
*.out

# CMake byggkataloger / CMake build directories
# Presets skapar build/<preset-namn>/ kataloger
# Presets create build/<preset-name>/ directories
build/
cmake-build-*/

# CMake User Presets — personliga inställningar, EJ delade
# CMake User Presets — personal settings, NOT shared
CMakeUserPresets.json

# IDE-konfigurationer / IDE configurations
.idea/
.vscode/
.cache/

# CLion genererar denna via CMake — behövs inte i git
# CLion generates this via CMake — not needed in git
compile_commands.json

# Övrigt / Others
*.txt
!CMakeLists.txt

# asm experiments
results.csv
results.json
*.csv
*.json
pmc_*/
*.perfetto
*.sqlite

# temporary
*.ll
*.bc
*.tmp

# editor backup files
*~
*.swp
*.swo
.*.swp

# ide
.idea/
.vscode/
*.code-workspace
cmake-build-*/
.cache/
compile_commands.json
